NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

QDRANT_URL=http://localhost:6333

# Мы будем использовать Ollama через OpenAI-совместимое API
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=deepseek-r1:1.5b # Используем небольшую модель для тестов, можно заменить на deepseek-v3
OLLAMA_EXTRACTOR_MODEL=qwen2.5:0.5b # Легкая модель для экстракции сущностей

# Настройки для Sentence Transformers (эмбеддинги)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
